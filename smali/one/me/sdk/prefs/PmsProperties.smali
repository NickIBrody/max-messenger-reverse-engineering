8\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00b6\u0005\u0010i\u001a\u0005\u0008\u00b7\u0005\u0010kR$\u0010\u00bb\u0005\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00b9\u0005\u0010i\u001a\u0005\u0008\u00ba\u0005\u0010kR$\u0010\u00be\u0005\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00bc\u0005\u0010i\u001a\u0005\u0008\u00bd\u0005\u0010kR$\u0010\u00c1\u0005\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00bf\u0005\u0010i\u001a\u0005\u0008\u00c0\u0005\u0010kR$\u0010\u00c4\u0005\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00c2\u0005\u0010i\u001a\u0005\u0008\u00c3\u0005\u0010kR$\u0010\u00c7\u0005\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00c5\u0005\u0010i\u001a\u0005\u0008\u00c6\u0005\u0010kR$\u0010\u00ca\u0005\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00c8\u0005\u0010i\u001a\u0005\u0008\u00c9\u0005\u0010kR$\u0010\u00cd\u0005\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00cb\u0005\u0010i\u001a\u0005\u0008\u00cc\u0005\u0010kR$\u0010\u00d0\u0005\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00ce\u0005\u0010i\u001a\u0005\u0008\u00cf\u0005\u0010kR$\u0010\u00d3\u0005\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00d1\u0005\u0010i\u001a\u0005\u0008\u00d2\u0005\u0010kR$\u0010\u00d6\u0005\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00d4\u0005\u0010i\u001a\u0005\u0008\u00d5\u0005\u0010kR$\u0010\u00d9\u0005\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00d7\u0005\u0010i\u001a\u0005\u0008\u00d8\u0005\u0010kR$\u0010\u00dc\u0005\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00da\u0005\u0010i\u001a\u0005\u0008\u00db\u0005\u0010kR$\u0010\u00df\u0005\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00dd\u0005\u0010i\u001a\u0005\u0008\u00de\u0005\u0010kR*\u0010\u00e2\u0005\u001a\u000e\u0012\n\u0012\u0008\u0012\u0004\u0012\u00020\u000c0\u001c0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00e0\u0005\u0010i\u001a\u0005\u0008\u00e1\u0005\u0010kR$\u0010\u00e5\u0005\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00e3\u0005\u0010i\u001a\u0005\u0008\u00e4\u0005\u0010kR$\u0010\u00e8\u0005\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00e6\u0005\u0010i\u001a\u0005\u0008\u00e7\u0005\u0010kR$\u0010\u00eb\u0005\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00e9\u0005\u0010i\u001a\u0005\u0008\u00ea\u0005\u0010kR$\u0010\u00ee\u0005\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00ec\u0005\u0010i\u001a\u0005\u0008\u00ed\u0005\u0010kR%\u0010\u00f2\u0005\u001a\t\u0012\u0005\u0012\u00030\u00ef\u00050\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00f0\u0005\u0010i\u001a\u0005\u0008\u00f1\u0005\u0010kR$\u0010\u00f5\u0005\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00f3\u0005\u0010i\u001a\u0005\u0008\u00f4\u0005\u0010kR%\u0010\u00f9\u0005\u001a\t\u0012\u0005\u0012\u00030\u00f6\u00050\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00f7\u0005\u0010i\u001a\u0005\u0008\u00f8\u0005\u0010kR$\u0010\u00fc\u0005\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00fa\u0005\u0010i\u001a\u0005\u0008\u00fb\u0005\u0010kR$\u0010\u00ff\u0005\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00fd\u0005\u0010i\u001a\u0005\u0008\u00fe\u0005\u0010kR$\u0010\u0082\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0080\u0006\u0010i\u001a\u0005\u0008\u0081\u0006\u0010kR$\u0010\u0085\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0083\u0006\u0010i\u001a\u0005\u0008\u0084\u0006\u0010kR$\u0010\u0088\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0086\u0006\u0010i\u001a\u0005\u0008\u0087\u0006\u0010kR$\u0010\u008b\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0089\u0006\u0010i\u001a\u0005\u0008\u008a\u0006\u0010kR$\u0010\u008e\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u008c\u0006\u0010i\u001a\u0005\u0008\u008d\u0006\u0010kR$\u0010\u0091\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u008f\u0006\u0010i\u001a\u0005\u0008\u0090\u0006\u0010kR$\u0010\u0094\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0092\u0006\u0010i\u001a\u0005\u0008\u0093\u0006\u0010kR$\u0010\u0096\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0095\u0006\u0010i\u001a\u0005\u0008\u0096\u0006\u0010kR$\u0010\u0099\u0006\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0097\u0006\u0010i\u001a\u0005\u0008\u0098\u0006\u0010kR$\u0010\u009c\u0006\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u009a\u0006\u0010i\u001a\u0005\u0008\u009b\u0006\u0010kR$\u0010\u009f\u0006\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u009d\u0006\u0010i\u001a\u0005\u0008\u009e\u0006\u0010kR$\u0010\u00a2\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00a0\u0006\u0010i\u001a\u0005\u0008\u00a1\u0006\u0010kR$\u0010\u00a5\u0006\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00a3\u0006\u0010i\u001a\u0005\u0008\u00a4\u0006\u0010kR$\u0010\u00a8\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00a6\u0006\u0010i\u001a\u0005\u0008\u00a7\u0006\u0010kR$\u0010\u00ab\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00a9\u0006\u0010i\u001a\u0005\u0008\u00aa\u0006\u0010kR$\u0010\u00ae\u0006\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00ac\u0006\u0010i\u001a\u0005\u0008\u00ad\u0006\u0010kR$\u0010\u00b1\u0006\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00af\u0006\u0010i\u001a\u0005\u0008\u00b0\u0006\u0010kR%\u0010\u00b5\u0006\u001a\t\u0012\u0005\u0012\u00030\u00b2\u00060\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00b3\u0006\u0010i\u001a\u0005\u0008\u00b4\u0006\u0010kR$\u0010\u00b8\u0006\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00b6\u0006\u0010i\u001a\u0005\u0008\u00b7\u0006\u0010kR$\u0010\u00bb\u0006\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00b9\u0006\u0010i\u001a\u0005\u0008\u00ba\u0006\u0010kR$\u0010\u00be\u0006\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00bc\u0006\u0010i\u001a\u0005\u0008\u00bd\u0006\u0010kR$\u0010\u00c1\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00bf\u0006\u0010i\u001a\u0005\u0008\u00c0\u0006\u0010kR$\u0010\u00c4\u0006\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00c2\u0006\u0010i\u001a\u0005\u0008\u00c3\u0006\u0010kR$\u0010\u00c7\u0006\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00c5\u0006\u0010i\u001a\u0005\u0008\u00c6\u0006\u0010kR$\u0010\u00ca\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00c8\u0006\u0010i\u001a\u0005\u0008\u00c9\u0006\u0010kR$\u0010\u00cd\u0006\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00cb\u0006\u0010i\u001a\u0005\u0008\u00cc\u0006\u0010kR$\u0010\u00d0\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00ce\u0006\u0010i\u001a\u0005\u0008\u00cf\u0006\u0010kR$\u0010\u00d3\u0006\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00d1\u0006\u0010i\u001a\u0005\u0008\u00d2\u0006\u0010kR$\u0010\u00d6\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00d4\u0006\u0010i\u001a\u0005\u0008\u00d5\u0006\u0010kR$\u0010\u00d9\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00d7\u0006\u0010i\u001a\u0005\u0008\u00d8\u0006\u0010kR$\u0010\u00dc\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00da\u0006\u0010i\u001a\u0005\u0008\u00db\u0006\u0010kR$\u0010\u00df\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00dd\u0006\u0010i\u001a\u0005\u0008\u00de\u0006\u0010kR$\u0010\u00e1\u0006\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00e0\u0006\u0010i\u001a\u0005\u0008\u00e1\u0006\u0010kR$\u0010\u00e4\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00e2\u0006\u0010i\u001a\u0005\u0008\u00e3\u0006\u0010kR$\u0010\u00e7\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00e5\u0006\u0010i\u001a\u0005\u0008\u00e6\u0006\u0010kR$\u0010\u00ea\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00e8\u0006\u0010i\u001a\u0005\u0008\u00e9\u0006\u0010kR$\u0010\u00ed\u0006\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00eb\u0006\u0010i\u001a\u0005\u0008\u00ec\u0006\u0010kR$\u0010\u00f0\u0006\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00ee\u0006\u0010i\u001a\u0005\u0008\u00ef\u0006\u0010kR$\u0010\u00f3\u0006\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00f1\u0006\u0010i\u001a\u0005\u0008\u00f2\u0006\u0010kR$\u0010\u00f6\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00f4\u0006\u0010i\u001a\u0005\u0008\u00f5\u0006\u0010kR$\u0010\u00f9\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00f7\u0006\u0010i\u001a\u0005\u0008\u00f8\u0006\u0010kR$\u0010\u00fc\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00fa\u0006\u0010i\u001a\u0005\u0008\u00fb\u0006\u0010kR$\u0010\u00ff\u0006\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00fd\u0006\u0010i\u001a\u0005\u0008\u00fe\u0006\u0010kR$\u0010\u0082\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0080\u0007\u0010i\u001a\u0005\u0008\u0081\u0007\u0010kR$\u0010\u0085\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0083\u0007\u0010i\u001a\u0005\u0008\u0084\u0007\u0010kR$\u0010\u0088\u0007\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0086\u0007\u0010i\u001a\u0005\u0008\u0087\u0007\u0010kR$\u0010\u008b\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0089\u0007\u0010i\u001a\u0005\u0008\u008a\u0007\u0010kR$\u0010\u008e\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u008c\u0007\u0010i\u001a\u0005\u0008\u008d\u0007\u0010kR$\u0010\u0091\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u008f\u0007\u0010i\u001a\u0005\u0008\u0090\u0007\u0010kR$\u0010\u0094\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0092\u0007\u0010i\u001a\u0005\u0008\u0093\u0007\u0010kR&\u0010\u0097\u0007\u001a\n\u0012\u0006\u0012\u0004\u0018\u00010\u000c0\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0095\u0007\u0010i\u001a\u0005\u0008\u0096\u0007\u0010kR$\u0010\u009a\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0098\u0007\u0010i\u001a\u0005\u0008\u0099\u0007\u0010kR$\u0010\u009d\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u009b\u0007\u0010i\u001a\u0005\u0008\u009c\u0007\u0010kR$\u0010\u00a0\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u009e\u0007\u0010i\u001a\u0005\u0008\u009f\u0007\u0010kR$\u0010\u00a3\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00a1\u0007\u0010i\u001a\u0005\u0008\u00a2\u0007\u0010kR$\u0010\u00a6\u0007\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00a4\u0007\u0010i\u001a\u0005\u0008\u00a5\u0007\u0010kR$\u0010\u00a9\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00a7\u0007\u0010i\u001a\u0005\u0008\u00a8\u0007\u0010kR$\u0010\u00ac\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00aa\u0007\u0010i\u001a\u0005\u0008\u00ab\u0007\u0010kR\'\u0010\u00af\u0007\u001a\u000b\u0012\u0007\u0012\u0005\u0018\u00010\u0086\u00040\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00ad\u0007\u0010i\u001a\u0005\u0008\u00ae\u0007\u0010kR%\u0010\u00b3\u0007\u001a\t\u0012\u0005\u0012\u00030\u00b0\u00070\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00b1\u0007\u0010i\u001a\u0005\u0008\u00b2\u0007\u0010kR$\u0010\u00b6\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00b4\u0007\u0010i\u001a\u0005\u0008\u00b5\u0007\u0010kR$\u0010\u00b9\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00b7\u0007\u0010i\u001a\u0005\u0008\u00b8\u0007\u0010kR$\u0010\u00bc\u0007\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00ba\u0007\u0010i\u001a\u0005\u0008\u00bb\u0007\u0010kR$\u0010\u00bf\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00bd\u0007\u0010i\u001a\u0005\u0008\u00be\u0007\u0010kR$\u0010\u00c2\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00c0\u0007\u0010i\u001a\u0005\u0008\u00c1\u0007\u0010kR$\u0010\u00c5\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00c3\u0007\u0010i\u001a\u0005\u0008\u00c4\u0007\u0010kR$\u0010\u00c8\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00c6\u0007\u0010i\u001a\u0005\u0008\u00c7\u0007\u0010kR$\u0010\u00cb\u0007\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00c9\u0007\u0010i\u001a\u0005\u0008\u00ca\u0007\u0010kR$\u0010\u00ce\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00cc\u0007\u0010i\u001a\u0005\u0008\u00cd\u0007\u0010kR$\u0010\u00d1\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00cf\u0007\u0010i\u001a\u0005\u0008\u00d0\u0007\u0010kR$\u0010\u00d4\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00d2\u0007\u0010i\u001a\u0005\u0008\u00d3\u0007\u0010kR$\u0010\u00d7\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00d5\u0007\u0010i\u001a\u0005\u0008\u00d6\u0007\u0010kR$\u0010\u00da\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00d8\u0007\u0010i\u001a\u0005\u0008\u00d9\u0007\u0010kR$\u0010\u00dd\u0007\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00db\u0007\u0010i\u001a\u0005\u0008\u00dc\u0007\u0010kR$\u0010\u00e0\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00de\u0007\u0010i\u001a\u0005\u0008\u00df\u0007\u0010kR$\u0010\u00e3\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00e1\u0007\u0010i\u001a\u0005\u0008\u00e2\u0007\u0010kR$\u0010\u00e6\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00e4\u0007\u0010i\u001a\u0005\u0008\u00e5\u0007\u0010kR$\u0010\u00e9\u0007\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00e7\u0007\u0010i\u001a\u0005\u0008\u00e8\u0007\u0010kR$\u0010\u00ec\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00ea\u0007\u0010i\u001a\u0005\u0008\u00eb\u0007\u0010kR$\u0010\u00ef\u0007\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00ed\u0007\u0010i\u001a\u0005\u0008\u00ee\u0007\u0010kR$\u0010\u00f2\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00f0\u0007\u0010i\u001a\u0005\u0008\u00f1\u0007\u0010kR$\u0010\u00f5\u0007\u001a\u0008\u0012\u0004\u0012\u00020\u000c0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00f3\u0007\u0010i\u001a\u0005\u0008\u00f4\u0007\u0010kR$\u0010\u00f8\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00f6\u0007\u0010i\u001a\u0005\u0008\u00f7\u0007\u0010kR$\u0010\u00fb\u0007\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00f9\u0007\u0010i\u001a\u0005\u0008\u00fa\u0007\u0010kR$\u0010\u00fe\u0007\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00fc\u0007\u0010i\u001a\u0005\u0008\u00fd\u0007\u0010kR$\u0010\u0081\u0008\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00ff\u0007\u0010i\u001a\u0005\u0008\u0080\u0008\u0010kR$\u0010\u0084\u0008\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0082\u0008\u0010i\u001a\u0005\u0008\u0083\u0008\u0010kR$\u0010\u0087\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0085\u0008\u0010i\u001a\u0005\u0008\u0086\u0008\u0010kR$\u0010\u008a\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0088\u0008\u0010i\u001a\u0005\u0008\u0089\u0008\u0010kR$\u0010\u008d\u0008\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u008b\u0008\u0010i\u001a\u0005\u0008\u008c\u0008\u0010kR%\u0010\u0091\u0008\u001a\t\u0012\u0005\u0012\u00030\u008e\u00080\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u008f\u0008\u0010i\u001a\u0005\u0008\u0090\u0008\u0010kR$\u0010\u0094\u0008\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0092\u0008\u0010i\u001a\u0005\u0008\u0093\u0008\u0010kR$\u0010\u0097\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0095\u0008\u0010i\u001a\u0005\u0008\u0096\u0008\u0010kR$\u0010\u009a\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u0098\u0008\u0010i\u001a\u0005\u0008\u0099\u0008\u0010kR$\u0010\u009d\u0008\u001a\u0008\u0012\u0004\u0012\u00020s0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u009b\u0008\u0010i\u001a\u0005\u0008\u009c\u0008\u0010kR$\u0010\u009f\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u009e\u0008\u0010i\u001a\u0005\u0008\u009f\u0008\u0010kR%\u0010\u00a3\u0008\u001a\t\u0012\u0005\u0012\u00030\u00a0\u00080\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00a1\u0008\u0010i\u001a\u0005\u0008\u00a2\u0008\u0010kR%\u0010\u00a7\u0008\u001a\t\u0012\u0005\u0012\u00030\u00a4\u00080\u001d8FX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00a5\u0008\u0010i\u001a\u0005\u0008\u00a6\u0008\u0010kR$\u0010\u00aa\u0008\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00a8\u0008\u0010i\u001a\u0005\u0008\u00a9\u0008\u0010kR$\u0010\u00ad\u0008\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00ab\u0008\u0010i\u001a\u0005\u0008\u00ac\u0008\u0010kR$\u0010\u00b0\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00ae\u0008\u0010i\u001a\u0005\u0008\u00af\u0008\u0010kR$\u0010\u00b3\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00b1\u0008\u0010i\u001a\u0005\u0008\u00b2\u0008\u0010kR$\u0010\u00b6\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00b4\u0008\u0010i\u001a\u0005\u0008\u00b5\u0008\u0010kR$\u0010\u00b9\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00b7\u0008\u0010i\u001a\u0005\u0008\u00b8\u0008\u0010kR$\u0010\u00bc\u0008\u001a\u0008\u0012\u0004\u0012\u00020\u000c0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00ba\u0008\u0010i\u001a\u0005\u0008\u00bb\u0008\u0010kR$\u0010\u00bf\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00bd\u0008\u0010i\u001a\u0005\u0008\u00be\u0008\u0010kR$\u0010\u00c2\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00c0\u0008\u0010i\u001a\u0005\u0008\u00c1\u0008\u0010kR$\u0010\u00c5\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00c3\u0008\u0010i\u001a\u0005\u0008\u00c4\u0008\u0010kR$\u0010\u00c8\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00c6\u0008\u0010i\u001a\u0005\u0008\u00c7\u0008\u0010kR$\u0010\u00cb\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00c9\u0008\u0010i\u001a\u0005\u0008\u00ca\u0008\u0010kR$\u0010\u00ce\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00cc\u0008\u0010i\u001a\u0005\u0008\u00cd\u0008\u0010kR$\u0010\u00d1\u0008\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00cf\u0008\u0010i\u001a\u0005\u0008\u00d0\u0008\u0010kR$\u0010\u00d4\u0008\u001a\u0008\u0012\u0004\u0012\u00020g0\u001d8GX\u0086\u0084\u0002\u00a2\u0006\u000e\n\u0005\u0008\u00d2\u0008\u0010i\u001a\u0005\u0008\u00d3\u0008\u0010kR$\u0010\u00d7\u0008\u001a\u0008\u0012\u0004\u0012\u0002020\u001d